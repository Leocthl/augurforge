# AugurForge environment — copy this file to `.env` and fill in.
# `.env` is gitignored; NEVER commit your key. Only the proxy (server/proxy.ts) reads the key.

# --- Client (Vite exposes ONLY VITE_-prefixed vars to the browser) ---
# Toggle the live Gemma-4-on-Cerebras pipeline. false = fully offline mock mode (no key needed).
VITE_USE_LIVE=false

# --- Server: key-proxy only. These are NOT exposed to the browser. ---
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=gemma-4-31b
PROXY_PORT=8787
# Comma-separated origins allowed to call the proxy (CORS). Defaults to the Vite dev server.
ALLOWED_ORIGINS=http://localhost:5173

# --- Speed-race comparator: OpenRouter Gemma 4 (Cerebras vs commodity GPUs) ---
# Runs the SAME Gemma 4 on OpenRouter so the race isolates inference hardware.
# Leave BASELINE_API_KEY blank to keep the comparator simulated (mock timing, labeled "(sim)").
# Get a key at https://openrouter.ai/keys — only the proxy reads it; never bundled to the client.
BASELINE_API_KEY=
BASELINE_BASE_URL=https://openrouter.ai/api/v1
# Use the SAME model Cerebras serves for a fair race. Verify the slug at https://openrouter.ai/models.
BASELINE_MODEL=google/gemma-4-31b-it
# Shown on the HUD's comparator column.
BASELINE_LABEL=OpenRouter · Gemma 4
# Optional OpenRouter attribution headers.
OPENROUTER_REFERER=http://localhost:5173
OPENROUTER_TITLE=AugurForge
